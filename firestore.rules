rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    // Removed strict email_verified check for this demo environment just in case, 
    // but the system prompt recommended it. I will keep request.auth != null
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // RBAC Helpers
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.role : null;
    }
    
    function isDirector() { return isSignedIn() && getUserRole() == 'director'; }
    function isSocialWorker() { return isSignedIn() && getUserRole() == 'social_worker'; }
    function isAccountant() { return isSignedIn() && getUserRole() == 'accountant'; }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
             data.email is string && data.email.size() >= 3 && data.email.size() <= 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role in ['director', 'social_worker', 'accountant'] &&
             data.createdAt is number;
    }

    function isValidChild(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'dateOfBirth', 'gender', 'status', 'createdBy', 'createdAt']) &&
             data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() <= 100 &&
             data.dateOfBirth is string && data.dateOfBirth.size() <= 20 &&
             data.gender in ['M', 'F'] &&
             data.status in ['active', 'adopted', 'transferred'] &&
             data.createdBy is string && data.createdBy == request.auth.uid &&
             data.createdAt is number;
    }

    function isValidChildUpdate(data) {
      return data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() <= 100 &&
             data.dateOfBirth is string && data.dateOfBirth.size() <= 20 &&
             data.gender in ['M', 'F'] &&
             data.status in ['active', 'adopted', 'transferred'] &&
             data.updatedAt is number &&
             data.createdBy == existing().createdBy &&
             data.createdAt == existing().createdAt;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['title', 'type', 'url', 'uploadedBy', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 50 &&
             data.url is string && data.url.size() > 0 && data.url.size() <= 1000 &&
             data.uploadedBy is string && data.uploadedBy == request.auth.uid &&
             data.createdAt is number;
    }

    function isValidDonor(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.createdAt is number;
    }

    function isValidDonation(data) {
      return data.keys().hasAll(['donorId', 'type', 'amount', 'itemDescription', 'date', 'recordedBy', 'createdAt']) &&
             data.donorId is string && data.donorId.size() > 0 && data.donorId.size() <= 128 &&
             data.type in ['money', 'in_kind'] &&
             (data.amount is number) &&
             (data.itemDescription is string) &&
             data.date is string && data.date.size() > 0 && data.date.size() <= 20 &&
             data.recordedBy is string && data.recordedBy == request.auth.uid &&
             data.createdAt is number;
    }

    // Rules
    match /users/{userId} {
      // Allow users to read their own profile, Directors can read all
      allow get: if isSignedIn() && (request.auth.uid == userId || isDirector());
      allow list: if isDirector();
      // Allow users to create their own profile (bootstrap)
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isDirector()) && isValidId(userId) && isValidUser(incoming());
    }

    match /children/{childId} {
      allow get: if isSignedIn() && isValidId(childId) && (isDirector() || isSocialWorker());
      allow list: if isSignedIn() && (isDirector() || isSocialWorker());
      allow create: if isSignedIn() && (isDirector() || isSocialWorker()) && isValidId(childId) && isValidChild(incoming());
      allow update: if isSignedIn() && (isDirector() || isSocialWorker()) && isValidId(childId) && isValidChildUpdate(incoming());
      allow delete: if isDirector() && isValidId(childId);
      
      match /documents/{documentId} {
        allow get: if isSignedIn() && isValidId(childId) && isValidId(documentId) && (isDirector() || isSocialWorker());
        allow list: if isSignedIn() && isValidId(childId) && (isDirector() || isSocialWorker());
        allow create: if isSignedIn() && (isDirector() || isSocialWorker()) && isValidId(childId) && isValidId(documentId) && isValidDocument(incoming());
        allow delete: if (isDirector() || isSocialWorker()) && isValidId(childId) && isValidId(documentId);
      }
    }
    
    match /donors/{donorId} {
      // Directors and accountants can access donors
      allow get: if isSignedIn() && isValidId(donorId) && (isDirector() || isAccountant());
      allow list: if isSignedIn() && (isDirector() || isAccountant());
      allow create: if isSignedIn() && (isDirector() || isAccountant()) && isValidId(donorId) && isValidDonor(incoming());
      allow update: if isSignedIn() && (isDirector() || isAccountant()) && isValidId(donorId) && isValidDonor(incoming());
      allow delete: if isDirector() && isValidId(donorId);
    }

    match /donations/{donationId} {
      allow get: if isSignedIn() && isValidId(donationId) && (isDirector() || isAccountant());
      allow list: if isSignedIn() && (isDirector() || isAccountant());
      allow create: if isSignedIn() && (isDirector() || isAccountant()) && isValidId(donationId) && isValidDonation(incoming());
      allow update: if isSignedIn() && (isDirector() || isAccountant()) && isValidId(donationId); // Simplified for now
      allow delete: if isDirector() && isValidId(donationId);
    }
  }
}
